# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================

# WalletConnect Project ID (get from https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# World ID App ID (get from https://developer.worldcoin.org)
VITE_WORLD_ID_APP_ID=app_staging_your_world_id_app_id
VITE_WORLD_ID_ACTION=verify-human-argentina

# Crossmint Client ID (get from https://crossmint.com)
VITE_CROSSMINT_CLIENT_ID=your_crossmint_client_id

# Scroll Network
VITE_SCROLL_RPC_URL=https://rpc.scroll.io
VITE_SCROLL_CHAIN_ID=534352

# Contract Addresses (deployed on Scroll Mainnet)
VITE_NOTARIAL_NFT_ADDRESS=0x...
VITE_PROPERTY_ESCROW_ADDRESS=0x...
VITE_USDC_ADDRESS=0x06eFdBFf2a14a7c8E15944D1F4A48F9F95F663A4

# Backend API
VITE_BACKEND_URL=http://localhost:3001
VITE_BACKEND_URL_PROD=https://notarial-api.vercel.app

# IPFS Gateway
VITE_IPFS_GATEWAY=https://nftstorage.link/ipfs/

# Wormhole
VITE_WORMHOLE_CONNECT_PROJECT_ID=your_wormhole_project_id

# Chainlink Price Feed (USD/ARS on Scroll)
VITE_CHAINLINK_USD_ARS_FEED=0x...

# ============================================
# BACKEND ENVIRONMENT VARIABLES
# ============================================

# Crossmint Server API Key (SECRET - never commit!)
CROSSMINT_API_KEY=sk_production_your_crossmint_api_key
CROSSMINT_COLLECTION_ID=your_collection_id

# NFT.Storage API Key (get from https://nft.storage)
NFT_STORAGE_API_KEY=your_nft_storage_api_key

# Scroll Network
SCROLL_RPC_URL=https://rpc.scroll.io
SCROLL_CHAIN_ID=534352

# Deployer Private Key (SECRET - never commit!)
PRIVATE_KEY=0xYourPrivateKeyHere

# Contract Addresses
NOTARIAL_NFT_ADDRESS=0x...
PROPERTY_ESCROW_ADDRESS=0x...

# Server Config
PORT=3001
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:5173

# ============================================
# SMART CONTRACT DEPLOYMENT
# ============================================

# Scroll API Key for verification (get from https://scrollscan.com)
SCROLL_API_KEY=your_scrollscan_api_key

# Deployer wallet
DEPLOYER_PRIVATE_KEY=0xYourPrivateKeyHere

# Gas settings
GAS_PRICE=1000000000
GAS_LIMIT=5000000

# ============================================
# OPTIONAL - ADVANCED FEATURES
# ============================================

# Telegram Bot (for Mini-App)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Lemon Wallet Integration
LEMON_API_KEY=your_lemon_api_key

# Analytics
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Sentry Error Tracking
VITE_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=your_sentry_auth_token
